## Web network config
# 31337 = local hardhat
# 11155111 = ethereum sepolia
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

## Backend API
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

## Optional explorer tx prefix. If omitted and chain=11155111,
## the UI falls back to https://sepolia.etherscan.io/tx/
# NEXT_PUBLIC_TX_EXPLORER_URL_PREFIX=https://sepolia.etherscan.io/tx

## Optional wallet auth
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
