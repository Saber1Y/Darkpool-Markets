PORT=4000

## Encryption mode: "local" (anvil/hardhat) or "sepolia"
FHEVM_ENCRYPTION_MODE=local

## Local mode RPC (used for fhevm_relayer_* + debug decrypt)
HARDHAT_RPC_URL=http://127.0.0.1:8545

## Sepolia mode RPC (used by Relayer SDK network provider)
# FHEVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

## Optional Relayer API key (if required by your access tier)
# ZAMA_FHEVM_API_KEY=your_zama_relayer_key

## Local-only decrypt guard
ENABLE_INSECURE_DECRYPT=true
# DECRYPT_API_TOKEN=replace_me

## Optional AI resolver
# OPENROUTER_API_KEY=your_openrouter_key
# OPENROUTER_MODEL=openai/gpt-4o-mini
